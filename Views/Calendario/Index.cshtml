<!-- Views/Calendario/Index.cshtml -->
@model List<proyectoIngSoft.Models.CalendarioEvento>
@{
    ViewData["Title"] = "Calendario de Festividades";
    var año = ViewBag.AñoActual;
    var mes = ViewBag.MesActual;
    var mesNombre = ViewBag.MesNombre;
    var fechaActual = ViewBag.FechaActual;
    var eventos = ViewBag.Eventos as List<proyectoIngSoft.Models.CalendarioEvento> ?? new List<proyectoIngSoft.Models.CalendarioEvento>();
}

<!-- Fuente Inter -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">

<style>
/* ===========================
   Estilos generales y layout
   =========================== */

:root{
  --bg-page: #fbf9ff;
  --card-bg: #ffffff;
  --purple-1: #6e4bff;
  --purple-2: #c08bff;
  --muted: #bfb7ef;
  --text-main: #342c4d;
  --tile-bg: #faf8ff;
  --tile-border: rgba(98,65,204,0.06);
  --today-bg: #f3e9ff;
  --detail-bg: linear-gradient(90deg, rgba(142,98,255,0.06), rgba(183,123,255,0.02));
  --radius-xl: 16px;
}

/* Tarjeta del calendario */
.calendar-card {
    background: #fff;
    border-radius: 1rem;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    padding: 1.2rem;
    width: 100%;
    max-width: 2000px;
    margin: 0 auto;
    transform: scale(0.7); /* Reduce al 80% del tamaño original */
    transform-origin: top center;
   
    
}

/* Ajuste leve en fuentes */
.calendar-card * {
    overflow: visible !important;
}
/* Header principal */
.header-top {
  background: linear-gradient(135deg, var(--purple-1) 0%, var(--purple-2) 100%);
  padding: 22px 26px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  color:white;
}
.header-left { display:flex; flex-direction:column; gap:6px; }
.header-title { font-size:28px; font-weight:800; display:flex; align-items:center; gap:12px; }
.header-subtitle { font-size:13px; opacity:0.95; font-weight:600; color: rgba(255,255,255,0.92); }

/* Buttons header */
.btn-navigation {
  background: rgba(255,255,255,0.10);
  color: white !important;
  border: 1px solid rgba(255,255,255,0.12);
  padding: 10px 18px;
  font-weight:700;
  border-radius:10px;
}

/* top small row */
.top-small {
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding: 12px 20px;
  border-bottom: 1px solid rgba(18,8,38,0.03);
  background: linear-gradient(90deg, rgba(139,92,246,0.02), rgba(255,255,255,0.00));
}

/* week names */
.weeknames { display:grid; grid-template-columns: repeat(7, 1fr); gap:12px; padding: 0 22px; margin-bottom:10px; }
.weeknames div { text-align:center; font-weight:700; color:var(--muted); font-size:13px; }

/* body layout */
.main-split {
  display:flex;
  align-items:flex-start;
  gap:20px;
  padding: 10px 20px 26px 20px;
}

/* Calendar area (left) */
.calendar-area {
  width: 100%;
  max-width: calc(100% - 0px);
  transition: width 300ms cubic-bezier(.2,.9,.25,1), transform 300ms ease;
  display:block;
}

/* side panel (hidden by default) */
.side-panel {
  width: 0;
  min-width: 0;
  max-width: 0;
  opacity: 0;
  transform: translateX(16px);
  transition: width 320ms cubic-bezier(.2,.9,.25,1), opacity 320ms ease, transform 320ms ease;
  overflow: hidden;
  display:flex;
  flex-direction:column;
}

/* when visible */
.main-split.with-panel .calendar-area {
  width: calc(100% - 380px);
  max-width: calc(100% - 380px);
}
.main-split.with-panel .side-panel {
  width: 360px;
  max-width: 360px;
  min-width: 360px;
  opacity: 1;
  transform: translateX(0);
}

/* calendar visual styles */
.grid {
  display:grid;
  grid-template-columns: repeat(7, 1fr);
  gap:12px;
}

/* cell */
.grid .cell {
  background: var(--tile-bg);
  min-height: 96px;
    padding: 12px;
    position: relative;
  border-radius: 12px;
  
  border: 1px solid var(--tile-border);
  transition: transform .12s ease, box-shadow .14s ease;
  display:flex;
  flex-direction:column;
  justify-content:flex-start;
  overflow:hidden;
}
.grid .cell.empty { background:#fbfbfd; color:rgba(52,44,77,0.28); }
.grid .cell.today { background: linear-gradient(135deg,#f6f2ff 0%,#efe8ff 100%); border:1px solid rgba(110,75,255,0.18); box-shadow:0 8px 24px rgba(110,75,255,0.08); }
.grid .cell:hover { transform: translateY(-6px); box-shadow: 0 22px 50px rgba(104,71,199,0.06); }
.grid .cell.selected { background: var(--card-bg); transform: translateY(-14px); box-shadow: 0 28px 60px rgba(98,65,204,0.14), 0 8px 22px rgba(98,65,204,0.06); border:1px solid rgba(98,65,204,0.09); display:flex; align-items:center; justify-content:center; }
.grid .cell .num { font-weight:800; font-size:15px; color:var(--text-main); margin-bottom:8px; }
.grid .cell.selected .num { color:var(--purple-1); font-size:17px; }

/* events in cell */
.grid .cell .events { position: absolute;
    bottom: 8px;
    left: 8px;
    right: 8px;
    display: flex;
    gap: 4px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    max-width: calc(100% - 16px);}
.grid .cell .dot {width: 8px;
    height: 8px;
    border-radius: 50%;
    box-shadow: 0 1px 0 rgba(0,0,0,0.06) inset;
    flex-shrink: 0;
    display: inline-block;}
.grid .cell .more { font-size: 10px;
    color: #6c6a7a;
    margin-left: 2px;
    flex-shrink: 0; }

/* detail bar below calendar */
.detail-bar {
  margin-top: 18px;
  padding: 12px 14px;
  border-radius:10px;
  background: var(--detail-bg);
  color: var(--purple-1);
  font-weight:700;
  border: 1px solid rgba(98,65,204,0.04);
  display:flex; align-items:center; gap:12px;
}

/* Side panel inner design */
.side-panel .panel-card {
  background: var(--card-bg);
  border-radius: 12px;
  box-shadow: 0 10px 30px rgba(84,64,237,0.06);
  border:1px solid rgba(98,65,204,0.03);
  padding: 14px;
  display:flex;
  flex-direction:column;
  height: 100%;
}

/* side header */
.side-header {
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  margin-bottom:12px;
}
.side-header .title {
  font-weight:800; color:var(--text-main); font-size:15px;
}
.side-header .btn-add {
  background: linear-gradient(90deg, var(--purple-1), var(--purple-2));
  border: none;
  color: white;
  padding: 8px 12px;
  border-radius: 10px;
  font-weight:700;
  box-shadow: 0 10px 30px rgba(110,75,255,0.12);
}

/* side content */
.side-body {
  overflow-y:auto;
  padding-right:6px;
  flex:1;
}

/* event item */
.side-body .evento-item {
  padding: 12px;
    margin-bottom: 12px;
    border-radius: 10px;
    border-left: 4px solid;
    background: #fff;
    box-shadow: 0 6px 20px rgba(84,64,237,0.03);
    transition: transform 0.2s ease;
}

.side-body .evento-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(84,64,237,0.08);
}

/* Estilos específicos para tipos de eventos */
.evento-feriado {
    border-left-color: #4A90E2 !important;
}

.evento-cumpleanos {
    border-left-color: #FF6B6B !important;
}

/* Badges para tipos de eventos */
.badge {
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 6px;
    font-weight: 600;
}

/* footer small note */
.side-footer {
  margin-top:12px;
  font-size:13px;
  color:var(--muted);
}

/* Estilos para el modal de cumpleaños */
.modal-cumpleanos .modal-content {
    border-radius: 12px;
    border: none;
    box-shadow: 0 20px 60px rgba(0,0,0,0.1);
}

.modal-cumpleanos .modal-header {
    border-bottom: 2px solid #e9ecef;
    padding: 20px 25px;
}

.modal-cumpleanos .modal-body {
    padding: 0;
}

.modal-cumpleanos .modal-footer {
    border-top: 1px solid #e9ecef;
    padding: 20px 25px;
}

/* Estilos para los empleados en los resultados */
.empleado-item {
    padding: 12px 15px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
}

.empleado-item:hover {
    background-color: #f7fafc;
    border-color: #6e4bff;
}

.empleado-item.seleccionado {
    background-color: #f0f4ff;
    border-color: #6e4bff;
}

.empleado-nombre {
    font-weight: 600;
    color: #2d3748;
    font-size: 14px;
}

.empleado-info {
    color: #718096;
    font-size: 12px;
    margin-top: 2px;
}

.empleado-empresa {
    color: #6e4bff;
    font-size: 11px;
    font-weight: 600;
    margin-top: 2px;
}

/* Estilos para empleados seleccionados */
.empleado-seleccionado {
    padding: 10px 15px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    margin-bottom: 8px;
    background-color: #f8fafc;
}

.empleado-seleccionado .empleado-nombre {
    font-size: 13px;
}

.empleado-seleccionado .empleado-info {
    font-size: 11px;
}

/* Scrollbar personalizado */
#resultadosEmpleados::-webkit-scrollbar,
#empleadosSeleccionados::-webkit-scrollbar {
    width: 6px;
}

#resultadosEmpleados::-webkit-scrollbar-track,
#empleadosSeleccionados::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 3px;
}

#resultadosEmpleados::-webkit-scrollbar-thumb,
#empleadosSeleccionados::-webkit-scrollbar-thumb {
    background: #cbd5e0;
    border-radius: 3px;
}

#resultadosEmpleados::-webkit-scrollbar-thumb:hover,
#empleadosSeleccionados::-webkit-scrollbar-thumb:hover {
    background: #a0aec0;
}

/* Secciones del modal */
.modal-section {
    padding: 20px 25px;
    border-bottom: 1px solid #f1f3f4;
}

.modal-section:last-child {
    border-bottom: none;
}

/* Campo de búsqueda con checkbox */
.busqueda-con-checkbox {
    border: 2px solid #e2e8f0;
    border-radius: 8px;
    overflow: hidden;
}

.busqueda-con-checkbox .input-group-text {
    background: white;
    border: none;
    padding: 0 15px;
}

.busqueda-con-checkbox .form-control {
    border: none;
    padding: 12px 0;
    font-size: 14px;
}

/* Mensajes de cumpleaños */
.mensajes-cumpleanos {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.mensajes-cumpleanos .form-check-label {
    font-size: 13px;
    line-height: 1.4;
}

/* responsive */
@@media (max-width: 1000px) {
  .main-split.with-panel .calendar-area { width: calc(100% - 320px); }
  .main-split.with-panel .side-panel { width: 320px; max-width:320px; min-width:320px; }
  .grid .cell { min-height:80px; }
}
@@media (max-width: 720px) {
  .main-split { flex-direction:column; }
  .main-split.with-panel .calendar-area { width:100%; }
  .main-split.with-panel .side-panel { width:100%; max-width:100%; min-width:100%; opacity:1; transform:none; margin-top:12px; }
  .side-panel { position:relative; }
}
</style>


    <div class="calendar-card">

      <!-- HEADER PRINCIPAL -->
      <div class="header-top">
        <div class="header-left">
          <div class="header-title">
            <i class="fas fa-calendar-alt" style="font-size:22px; opacity:0.95"></i>
            <span>@mesNombre @año</span>
          </div>
          <div class="header-subtitle">Gestión de cumpleaños y festividades</div>
        </div>

        <div class="d-flex align-items-center" style="gap:12px;">
          <div class="btn-group" role="group" aria-label="Navegación de mes" style="z-index:2;">
            @{
                var mesAnterior = mes - 1;
                var añoAnterior = año;
                if (mesAnterior < 1)
                {
                    mesAnterior = 12;
                    añoAnterior = año - 1;
                }
                
                var mesSiguiente = mes + 1;
                var añoSiguiente = año;
                if (mesSiguiente > 12)
                {
                    mesSiguiente = 1;
                    añoSiguiente = año + 1;
                }
            }
            <a href="@Url.Action("Index", new { año = añoAnterior, mes = mesAnterior })" class="btn btn-navigation">
              <i class="fas fa-chevron-left me-2"></i>Anterior
            </a>
            <a href="@Url.Action("Index", new { año = fechaActual.Year, mes = fechaActual.Month })" class="btn btn-navigation">
              Hoy
            </a>
            <a href="@Url.Action("Index", new { año = añoSiguiente, mes = mesSiguiente })" class="btn btn-navigation">
              Siguiente <i class="fas fa-chevron-right ms-2"></i>
            </a>
          </div>
        </div>
      </div>

      <!-- TOP SMALL ROW -->
      <div class="top-small">
        <div class="month-small">@mesNombre @año</div>
        <div class="controls-small" aria-hidden="true">
          <div class="control-decor" title="Mes anterior">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="#3b2e63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/></svg>
          </div>
          <div class="control-decor" title="Mes siguiente">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="#3b2e63" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.85"/></svg>
          </div>
        </div>
      </div>

      <!-- MAIN SPLIT: calendar-area (left) + side-panel (right, hidden by default) -->
      <div class="main-split" id="mainSplit">
        <!-- Calendar area -->
        <div class="calendar-area">
          <!-- Week names -->
          <div class="weeknames" aria-hidden="true">
            <div>Dom</div><div>Lun</div><div>Mar</div><div>Mié</div><div>Jue</div><div>Vie</div><div>Sáb</div>
          </div>

          <!-- Grid -->
          <div class="grid" id="grid" role="grid" aria-label="Días del mes" style="padding: 0 22px 12px 22px;">
    @{
        var primerDiaMes = new DateTime(año, mes, 1);
        var ultimoDiaMes = primerDiaMes.AddMonths(1).AddDays(-1);
        var primerDiaCalendario = primerDiaMes.AddDays(-((int)primerDiaMes.DayOfWeek + 6) % 7);
        for (int semana = 0; semana < 6; semana++)
        {
            for (int diaSemana = 0; diaSemana < 7; diaSemana++)
            {
                var fechaActualCalendario = primerDiaCalendario.AddDays(semana * 7 + diaSemana);
                var esMesActual = fechaActualCalendario.Month == mes;
                var esHoy = fechaActualCalendario.Date == fechaActual.Date;
                
                // SOLO eventos que ocurren exactamente en este día
                var eventosDia = eventos
                    .Where(e => e.FechaInicio.Date == fechaActualCalendario.Date)
                    .ToList();

                if (esMesActual)
                {
                    <div class="cell @(esHoy ? "today" : "")"
                         data-fecha="@fechaActualCalendario.ToString("yyyy-MM-dd")"
                         data-año="@fechaActualCalendario.Year"
                         data-mes="@fechaActualCalendario.Month"
                         data-dia="@fechaActualCalendario.Day"
                         role="gridcell">
                        <div class="num">@fechaActualCalendario.Day</div>
                        @if (eventosDia.Any())
                        {
                            <div class="events">
                                @foreach (var evento in eventosDia.Take(3))
                                {
                                    <div class="dot" style="background-color:@evento.Color" title="@evento.Titulo"></div>
                                }
                                @if (eventosDia.Count > 3)
                                {
                                    <div class="more">+@(eventosDia.Count - 3)</div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="cell empty">
                        <div class="num text-muted">@fechaActualCalendario.Day</div>
                    </div>
                }
            }
        }
    }
</div>

          <!-- detalle inferior -->
          <div style="padding: 0 22px 22px 22px;">
            <div class="detail-bar" id="detailBar" aria-live="polite">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M19 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z" stroke="currentColor" stroke-opacity="0.2" stroke-width="1.6" stroke-linejoin="round"/></svg>
              <div id="detailText">Selecciona un día</div>
            </div>
          </div>
        </div>

        <!-- Side panel (hidden initially) -->
        <div class="side-panel" id="sidePanel" aria-hidden="true">
          <div class="panel-card">
            <div class="side-header">
              <div class="title" id="detalleDiaTitle">Eventos del Día</div>
              <!-- Botón Agregar -->
              <button id="btnAgregarEvento" class="btn-add" type="button">
                <i class="fas fa-plus me-2"></i>Agregar
              </button>
            </div>

            <div class="side-body" id="detalleDiaContent">
              <div class="text-center text-muted py-4"><i class="fas fa-info-circle fa-2x mb-2"></i><p>Seleccione un día para ver los eventos</p></div>
            </div>

            <div class="side-footer small-muted">
              Los eventos se muestran aquí. El panel permanecerá abierto hasta recargar.
            </div>
          </div>
        </div>
      </div>
    </div>


<!-- Modal para Agregar Cumpleaños -->
<div class="modal fade modal-cumpleanos" id="modalAgregarEvento" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <!-- Header del Modal -->
            <div class="modal-header">
                <h5 class="modal-title fw-bold" style="color: #2d3748; font-size: 18px;">
                    <i class="fas fa-birthday-cake me-2" style="color: #6e4bff;"></i>
                    Agregar Cumpleaños de Trabajadores
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
