                        Fecha de Cumpleaños
                    </label>
                    <input type="date" class="form-control" id="fechaCumpleanos" required 
                           style="border: 2px solid #e2e8f0; border-radius: 8px; padding: 10px; font-size: 14px;">
                </div>

                <!-- Buscar Trabajador -->
