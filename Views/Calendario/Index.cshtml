                    </div>
                    
                    <div id="empleadosSeleccionados" style="max-height: 150px; overflow-y: auto;">
                        <div class="text-center text-muted py-3" style="font-size: 14px;">
                            No hay trabajadores seleccionados
                        </div>
                    </div>
                </div>

                <!-- Mensaje Programado -->
                <div class="modal-section">
                    <label class="form-label fw-semibold" style="color: #2d3748; margin-bottom: 15px; display: block;">
                        Mensaje Programado
                    </label>
                    <div class="small text-muted mb-3" style="font-size: 13px;">
                        Se enviará automáticamente uno de estos mensajes:
                    </div>
                    
                    <div class="mensajes-cumpleanos">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mensajeCumpleanos" value="Feliz cumpleaños te desea la familia Norlys" checked>
                            <label class="form-check-label small">
                                Feliz cumpleaños te desea la familia Norlys
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mensajeCumpleanos" value="Se te aprecia mucho por trabajar con nosotros">
                            <label class="form-check-label small">
                                Se te aprecia mucho por trabajar con nosotros
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mensajeCumpleanos" value="Que tengas un día maravilloso, feliz cumpleaños de parte de Norlys">
                            <label class="form-check-label small">
                                Que tengas un día maravilloso, feliz cumpleaños de parte de Norlys
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mensajeCumpleanos" value="Eres parte importante de nuestro equipo, feliz cumpleaños">
                            <label class="form-check-label small">
                                Eres parte importante de nuestro equipo, feliz cumpleaños
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="mensajeCumpleanos" value="Te deseamos lo mejor en tu día especial, familia Norlys">
                            <label class="form-check-label small">
                                Te deseamos lo mejor en tu día especial, familia Norlys
                            </label>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer del Modal -->
            <div class="modal-footer">
               
                <button type="button" class="btn btn-primary" id="btnGuardarCumpleanos"
                        style="background: linear-gradient(135deg, #6e4bff, #8b5cf6); border: none; padding: 10px 25px; border-radius: 8px; font-weight: 600;">
                    <i class="fas fa-birthday-cake me-2"></i>Agregar Cumpleaños
                </button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade modal-cumpleanos" id="modalAgregarFestivo" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <!-- Header del Modal -->
            <div class="modal-header">
                <h5 class="modal-title fw-bold" style="color: #2d3748; font-size: 18px;">
                    <i class="fas fa-calendar-day me-2" style="color: #4A90E2;"></i>
                    Agregar Día Festivo
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <!-- Fecha del Festivo -->
                <div class="modal-section">
                    <label class="form-label fw-semibold" style="color: #2d3748; margin-bottom: 10px; display: block;">
                        Fecha del Festivo
                    </label>
                    <input type="date" class="form-control" id="fechaFestivo" required 
                           style="border: 2px solid #e2e8f0; border-radius: 8px; padding: 10px; font-size: 14px;">
                </div>

                <!-- Título del Festivo -->
                <div class="modal-section">
                    <label class="form-label fw-semibold" style="color: #2d3748; margin-bottom: 10px; display: block;">
                        Título del Festivo
                    </label>
                    <input type="text" class="form-control" id="tituloFestivo" 
                           placeholder="Ej: Combate de Angamos, Día del Trabajo..."
                           style="border: 2px solid #e2e8f0; border-radius: 8px; padding: 10px; font-size: 14px;">
                </div>

                <!-- Descripción -->
                <div class="modal-section">
                    <label class="form-label fw-semibold" style="color: #2d3748; margin-bottom: 10px; display: block;">
                        Descripción (Opcional)
                    </label>
                    <textarea class="form-control" id="descripcionFestivo" rows="3"
                              placeholder="Descripción adicional del festivo..."
                              style="border: 2px solid #e2e8f0; border-radius: 8px; padding: 10px; font-size: 14px;"></textarea>
                </div>
            </div>

            <!-- Footer del Modal -->
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Cancelar
                </button>
                <button type="button" class="btn btn-primary" id="btnGuardarFestivo"
                        style="background: linear-gradient(135deg, #4A90E2, #357ABD); border: none; padding: 10px 25px; border-radius: 8px; font-weight: 600;">
                    <i class="fas fa-calendar-plus me-2"></i>Guardar Festivo
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('Documento listo - calendario con múltiples eventos');

            let empleadosSeleccionados = [];
            let todosEmpleados = [];
            let panelOpen = false;
            const $mainSplit = $('#mainSplit');
            const $sidePanel = $('#sidePanel');

            // ========== FUNCIONALIDAD DEL CALENDARIO ==========

            // Click en día del calendario
            $(document).on('click', '.cell:not(.empty)', function() {
                var año = $(this).data('año');
                var mes = $(this).data('mes');
                var dia = $(this).data('dia');
                var fecha = $(this).data('fecha');

                console.log('Día seleccionado:', { año: año, mes: mes, dia: dia, fecha: fecha });

                // Abrir panel si no está abierto
                if (!panelOpen) {
                    $mainSplit.addClass('with-panel');
                    $sidePanel.attr('aria-hidden', 'false');
                    panelOpen = true;
                }

                // Actualizar título del panel y detalle inferior
                $('#detalleDiaTitle').text('Eventos del Día');
                var pretty = formatFechaShort(fecha);
                $('#detailText').text(pretty);

                // Cargar eventos del día
                cargarEventosDia(año, mes, dia);

                // Marcar visualmente la celda seleccionada
                $('.grid .cell.selected').removeClass('selected');
                $(this).addClass('selected');
            });

            // Botón agregar evento (dentro del panel) - Ahora muestra opciones
            $(document).on('click', '#btnAgregarEvento', function () {
                console.log('Botón agregar evento clickeado - mostrando opciones');
                
                // Crear menú de opciones
                const opcionesHtml = `
                    <div class="text-center p-4">
                        <h6 class="mb-3">¿Qué tipo de evento deseas agregar?</h6>
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-outline-primary btn-agregar-tipo" data-tipo="cumpleanos">
                                <i class="fas fa-birthday-cake me-2"></i>Agregar Cumpleaños
                            </button>
                            <button type="button" class="btn btn-outline-info btn-agregar-tipo" data-tipo="festivo">
                                <i class="fas fa-calendar-day me-2"></i>Agregar Día Festivo
                            </button>
                        </div>
                    </div>
                `;
                
                $('#detalleDiaContent').html(opcionesHtml);
            });

            // Manejar selección de tipo de evento
            $(document).on('click', '.btn-agregar-tipo', function() {
                const tipo = $(this).data('tipo');
                
                if (tipo === 'cumpleanos') {
                    // Mostrar modal de cumpleaños
                    const modalElement = document.getElementById('modalAgregarEvento');
                    const modal = new bootstrap.Modal(modalElement);
                    modal.show();
                } else if (tipo === 'festivo') {
                    // Mostrar modal de festivo
                    const modalElement = document.getElementById('modalAgregarFestivo');
                    const modal = new bootstrap.Modal(modalElement);
                    
                    // Si hay un día seleccionado, establecer esa fecha
                    const celdaSeleccionada = $('.grid .cell.selected');
                    if (celdaSeleccionada.length > 0) {
                        const fechaSeleccionada = celdaSeleccionada.data('fecha');
                        $('#fechaFestivo').val(fechaSeleccionada);
                    } else {
                        // Establecer fecha actual por defecto
                        const hoy = new Date().toISOString().split('T')[0];
                        $('#fechaFestivo').val(hoy);
                    }
                    
                    modal.show();
                }
            });

            // ========== FUNCIONALIDAD DEL MODAL DE CUMPLEAÑOS ==========
            inicializarModalCumpleanos();

            // ========== FUNCIONALIDAD DEL MODAL DE FESTIVOS ==========
            function inicializarModalFestivos() {
                // Guardar evento festivo
                $('#btnGuardarFestivo').click(function() {
                    guardarEventoFestivo();
                });
            }

            function guardarEventoFestivo() {
                const fechaFestivo = $('#fechaFestivo').val();
                const tituloFestivo = $('#tituloFestivo').val().trim();
                const descripcionFestivo = $('#descripcionFestivo').val().trim();

                if (!fechaFestivo) {
                    alert('❌ Por favor seleccione una fecha para el festivo');
                    return;
                }

                if (!tituloFestivo) {
                    alert('❌ Por favor ingrese un título para el festivo');
                    return;
                }

                // Mostrar loading
                const $btnGuardar = $('#btnGuardarFestivo');
                const originalText = $btnGuardar.html();
                $btnGuardar.html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...');
                $btnGuardar.prop('disabled', true);

                const eventoData = {
                    Titulo: tituloFestivo,
                    Descripcion: descripcionFestivo,
                    TipoEvento: 'Feriado',
                    Color: '#4A90E2', // Azul para festivos
                    FechaInicio: fechaFestivo,
                    FechaFin: null,
                    IdUser: null // Los festivos no están asociados a un usuario
                };

                $.ajax({
                    url: '@Url.Action("AgregarEventoFestivo", "Calendario")',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(eventoData),
                    success: function(response) {
                        if (response.success) {
                            alert('✅ Evento festivo agregado correctamente');
                            const modal = bootstrap.Modal.getInstance(document.getElementById('modalAgregarFestivo'));
                            modal.hide();
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            alert('❌ Error: ' + response.message);
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error guardando evento festivo:', error);
                        alert('❌ Error al guardar el evento festivo');
                    },
                    complete: function() {
                        $btnGuardar.html(originalText);
                        $btnGuardar.prop('disabled', false);
                    }
                });
            }

            // ========== FUNCIONES COMPARTIDAS ==========

            // Buscar empleados
            function buscarEmpleados(termino) {
                $.getJSON('@Url.Action("BuscarEmpleados", "Calendario")', { termino: termino })
                    .done(function(empleados) {
                        todosEmpleados = empleados;
                        mostrarResultadosEmpleados(empleados);
                    })
                    .fail(function(error) {
                        console.error('Error buscando empleados:', error);
                        $('#resultadosEmpleados').html('<div class="text-center text-muted py-3">Error al buscar empleados</div>').show();
                    });
            }

            // Mostrar resultados de búsqueda
            function mostrarResultadosEmpleados(empleados) {
                const $resultados = $('#resultadosEmpleados');
                $resultados.empty();

                if (empleados.length === 0) {
                    $resultados.html('<div class="text-center text-muted py-3">No se encontraron empleados</div>');
                } else {
                    empleados.forEach(empleado => {
                        const estaSeleccionado = empleadosSeleccionados.some(e => e.id === empleado.id);
                        const empleadoHtml = `
                            <div class="empleado-item ${estaSeleccionado ? 'seleccionado' : ''}" 
                                 data-empleado-id="${empleado.id}"
                                 data-empleado-nombre="${empleado.nombre} ${empleado.apellidos}"
                                 data-empleado-dni="${empleado.dni}"
                                 data-empleado-cargo="${empleado.cargo}">
                                <div class="empleado-nombre">${empleado.nombre} ${empleado.apellidos}</div>
                                <div class="empleado-info">DNI: ${empleado.dni}</div>
                                <div class="empleado-info">${empleado.cargo}</div>
                                <div class="empleado-empresa">Norlys</div>
                            </div>
                        `;
                        $resultados.append(empleadoHtml);
                    });

                    // Agregar evento click a los empleados
                    $resultados.find('.empleado-item').click(function() {
                        const empleadoId = $(this).data('empleado-id');
                        const empleado = todosEmpleados.find(e => e.id === empleadoId);
                        
                        if (empleado) {
                            const index = empleadosSeleccionados.findIndex(e => e.id === empleadoId);
                            if (index === -1) {
                                // Agregar empleado
                                empleadosSeleccionados.push(empleado);
                                $(this).addClass('seleccionado');
                            } else {
                                // Remover empleado
                                empleadosSeleccionados.splice(index, 1);
                                $(this).removeClass('seleccionado');
                            }
                            actualizarEmpleadosSeleccionados();
                        }
                    });
                }
                
                $resultados.show();
            }

            // Actualizar lista de empleados seleccionados
            function actualizarEmpleadosSeleccionados() {
                const $seleccionados = $('#empleadosSeleccionados');
                const $contador = $('#contadorSeleccionados');
                
                $contador.text(`(${empleadosSeleccionados.length} seleccionados)`);
                
                if (empleadosSeleccionados.length === 0) {
                    $seleccionados.html('<div class="text-center text-muted py-3" style="font-size: 14px;">No hay trabajadores seleccionados</div>');
                } else {
                    $seleccionados.empty();
                    empleadosSeleccionados.forEach(empleado => {
                        const empleadoHtml = `
                            <div class="empleado-seleccionado">
                                <div class="empleado-nombre">${empleado.nombre} ${empleado.apellidos}</div>
                                <div class="empleado-info">DNI: ${empleado.dni} • ${empleado.cargo}</div>
                                <div class="empleado-empresa">Norlys</div>
                            </div>
                        `;
                        $seleccionados.append(empleadoHtml);
                    });
                }
            }

            // Guardar cumpleaños
            function guardarCumpleanos() {
    const fechaCumpleanos = $('#fechaCumpleanos').val();
    const mensajeSeleccionado = $('input[name="mensajeCumpleanos"]:checked').val();

    if (!fechaCumpleanos) {
        alert('❌ Por favor seleccione una fecha de cumpleaños');
        return;
    }

    if (empleadosSeleccionados.length === 0) {
        alert('❌ Por favor seleccione al menos un trabajador');
        return;
    }

    // Mostrar loading
    const $btnGuardar = $('#btnGuardarCumpleanos');
    const originalText = $btnGuardar.html();
    $btnGuardar.html('<i class="fas fa-spinner fa-spin me-2"></i>Guardando...');
    $btnGuardar.prop('disabled', true);

    // Crear eventos de cumpleaños para cada empleado seleccionado
    const promesas = empleadosSeleccionados.map(empleado => {
        const eventoData = {
            Titulo: `Cumpleaños de ${empleado.nombre} ${empleado.apellidos}`,
            Descripcion: mensajeSeleccionado,
            TipoEvento: 'Cumpleaños',
            Color: '#FF6B6B', // Color rojo para cumpleaños
            FechaInicio: fechaCumpleanos,
            FechaFin: null,
            IdUser: empleado.id
        };

        return $.ajax({
            url: '@Url.Action("AgregarEvento", "Calendario")',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(eventoData)
        });
    });

    // Ejecutar todas las promesas
    Promise.all(promesas)
        .then(responses => {
            const todosExitosos = responses.every(r => r.success);
            const algunosErrores = responses.some(r => !r.success);
            
            if (todosExitosos) {
                alert('✅ Cumpleaños agregados correctamente');
                const modal = bootstrap.Modal.getInstance(document.getElementById('modalAgregarEvento'));
                modal.hide();
                
                // Recargar la página para mostrar los nuevos puntos en el calendario
                setTimeout(() => location.reload(), 1000);
            } else if (algunosErrores) {
                alert('⚠ Algunos cumpleaños no se pudieron guardar, pero otros sí.');
                const modal = bootstrap.Modal.getInstance(document.getElementById('modalAgregarEvento'));
                modal.hide();
                setTimeout(() => location.reload(), 1000);
            } else {
                alert('❌ Error al guardar los cumpleaños');
            }
        })
        .catch(error => {
            console.error('Error guardando cumpleaños:', error);
            alert('❌ Error al guardar los cumpleaños');
        })
        .finally(() => {
            $btnGuardar.html(originalText);
            $btnGuardar.prop('disabled', false);
        });
}

            // Cargar eventos del día
            function cargarEventosDia(año, mes, dia) {
    $('#detalleDiaContent').html('<div class="text-center"><div class="spinner-border text-primary" role="status"></div><p class="mt-2">Cargando eventos...</p></div>');

    $.getJSON('@Url.Action("GetEventosDia", "Calendario")', { año: año, mes: mes, dia: dia })
        .done(function(eventos) {
            console.log('Eventos recibidos del servidor:', eventos); // DEBUG
            
            var contenido = '';
            if (eventos.length === 0) {
                contenido = '<div class="text-center text-muted py-4"><i class="fas fa-calendar-times fa-3x mb-3"></i><p>No hay eventos programados para este día.</p></div>';
            } else {
                eventos.forEach(function(evento) {
                    console.log('Procesando evento:', evento); // DEBUG individual
                    
                    // Verificar y asignar valores con fallbacks
                    var tituloMostrar = evento.Titulo || evento.titulo || 'Sin título';
                    var descripcionMostrar = evento.Descripcion || evento.descripcion || '';
                    var tipoEvento = evento.TipoEvento || evento.tipoEvento || 'Evento';
                    var color = evento.Color || evento.color || '#007bff';
                    
                    // Debug de cada propiedad
                    console.log('Titulo:', tituloMostrar, 'Descripcion:', descripcionMostrar);
                    
                    var empleadoInfo = '';
                    if (evento.Empleado || evento.empleado) {
                        var empleadoNombre = evento.Empleado || evento.empleado;
                        var empleadoDni = evento.Dni || evento.dni || '';
                        empleadoInfo = `<div class="small mt-2"><i class="fas fa-user me-1"></i><strong>Empleado:</strong> ${empleadoNombre} <span class="text-muted">(${empleadoDni})</span></div>`;
                    }
                    
                    contenido += `
                        <div class="evento-item" style="border-left-color: ${color}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="fw-bold text-dark">${tituloMostrar}</div>
                                <span class="badge" style="background-color: ${color}">${tipoEvento}</span>
                            </div>
                            ${descripcionMostrar ? `<div class="small text-muted mt-1">${descripcionMostrar}</div>` : ''}
                            ${empleadoInfo}
                        </div>
                    `;
                });
            }
            $('#detalleDiaContent').html(contenido);
        })
        .fail(function(xhr, status, error) {
            console.error('Error cargando eventos:', error);
            console.log('Respuesta del servidor:', xhr.responseText);
            $('#detalleDenidoContent').html('<div class="alert alert-danger"><i class="fas fa-exclamation-triangle me-2"></i>Error al cargar los eventos</div>');
        });
}

            // Formato fechas
            function formatFechaShort(fechaStr) {
                if (!fechaStr) return '';
                var d = new Date(fechaStr);
                var meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
                var dias = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
                return dias[d.getDay()] + ', ' + d.getDate() + ' de ' + meses[d.getMonth()] + ' de ' + d.getFullYear();
            }

            // Reinicializar cuando se muestra el modal de cumpleaños
            $('#modalAgregarEvento').on('show.bs.modal', function() {
                empleadosSeleccionados = [];
                actualizarEmpleadosSeleccionados();
                $('#resultadosEmpleados').hide().empty();
                $('#buscarEmpleadoInput').val('');
                
                // Establecer fecha actual por defecto
                const hoy = new Date().toISOString().split('T')[0];
                $('#fechaCumpleanos').val(hoy);
            });

            // Reinicializar cuando se muestra el modal de festivos
            $('#modalAgregarFestivo').on('show.bs.modal', function() {
                $('#tituloFestivo').val('');
                $('#descripcionFestivo').val('');
            });

            // Inicialización
            inicializarModalFestivos();

            function inicializarModalCumpleanos() {
                // Configurar búsqueda en tiempo real
                $('#buscarEmpleadoInput').on('input', function() {
                    const termino = $(this).val().trim();
                    if (termino.length >= 2) {
                        buscarEmpleados(termino);
                    } else {
                        $('#resultadosEmpleados').hide().empty();
                    }
                });

                // Seleccionar todos los empleados
                $('#seleccionarTodos').click(function(e) {
                    e.preventDefault();
                    if (todosEmpleados.length > 0) {
                        empleadosSeleccionados = [...todosEmpleados];
                        actualizarEmpleadosSeleccionados();
                        $('#resultadosEmpleados').hide();
                        $('#buscarEmpleadoInput').val('');
                    }
                });

                // Guardar cumpleaños
                $('#btnGuardarCumpleanos').click(guardarCumpleanos);
            }
        });


        function debugEventos() {
    var año = 2024;
    var mes = 11;
    var dia = 7;
    
    $.getJSON('@Url.Action("GetEventosDia", "Calendario")', { año: año, mes: mes, dia: dia })
        .done(function(eventos) {
            console.log('=== DEBUG EVENTOS ===');
            console.log('Eventos crudos:', eventos);
            eventos.forEach(function(evento, index) {
                console.log(`Evento ${index + 1}:`, {
                    IdEvento: evento.IdEvento,
                    Titulo: evento.Titulo,
                    Descripcion: evento.Descripcion,
                    TipoEvento: evento.TipoEvento,
                    Color: evento.Color,
                    Empleado: evento.Empleado,
                    Dni: evento.Dni
                });
            });
        });
}
    </script>
}