    border: 1px solid #ddd;
    border-radius: 6px;
    font-size: 14px;
    background: #f9f9f9;
}

.documentos-section h4 {
    margin: 1px 0 10px;
    font-size: 16px;
}

.upload-box {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.upload-area {
    border: 2px dashed #ccc;
    border-radius: 8px;
    padding: 25px;
    text-align: center;
    color: #666;
    font-size: 14px;
    cursor: pointer;
    position: relative;
}
.upload-area input[type="file"] {
    position: absolute;
    opacity: 0;
    top: 0; left: 0; width: 100%; height: 100%;
    cursor: pointer;
}
.upload-area span {
    font-size: 12px;
    color: #999;
}

.form-actions {
    text-align: right;
    margin-top: 0px;
}


.form-actions {
    grid-column: span 2;
    text-align: right;
    
}
.btn-submit {
    background: #111;
    color: white;
    border: none;
    padding: 10px 20px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.3s ease;
}

.btn-submit:hover {
    background: #000;
}

.documentos-section {
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid #e5e7eb;
}

.documentos-section h4 {
    margin-bottom: 15px;
    font-size: 16px;
    font-weight: 600;
}

.upload-box {
    flex: 1;
    display: flex;
    flex-direction: column;
}

.upload-area {
    border: 2px dashed #ccc;
    border-radius: 8px;
    padding: 25px;
    text-align: center;
    color: #666;
    font-size: 14px;
    cursor: pointer;
    position: relative;
    background: #fafafa;
    transition: all 0.3s ease;
}

.upload-area:hover {
    border-color: #999;
    background: #f5f5f5;
}

.upload-area .file-input {
    display: none;
}

.upload-icon {
    font-size: 32px;
    margin-bottom: 10px;
}

.upload-area p {
    margin: 0;
