@model proyectoIngSoft.Models.Fallecimiento

@{
    ViewData["Title"] = "Registrar Fallecimiento";
}


<div class="solicitud-container">

    <div class="header-bar">
    <a asp-controller="TipoSolicitud" asp-action="Index" class="btn-back">
        ← Volver
    </a>
    <div class="header-right">
        <span class="label-inline">Solicitud de:</span>
        <select id="tipoSolicitud" class="form-select">
            <option value="@Url.Action("Index","Fallecimiento")">Fallecimiento Familiar</option>
            <option value="@Url.Action("Index","Maternidad")">Maternidad</option>
            <option value="@Url.Action("Index","Accidente")">Accidente</option>
            <option value="@Url.Action("Index","Enfermedad")">Enfermedad</option>
            <option value="@Url.Action("Index","Paternidad")">Paternidad</option>
            <option value="@Url.Action("Index","EnfermedadFam")">Enfermedad Familiar</option>
        </select>
    </div>
</div>

    @if (ViewData["Message"] != null)
    {
        <div class="alert alert-danger" role="alert">
            @ViewData["Message"]
        </div>
    }

    <form method="post" asp-action="Registrar" enctype="multipart/form-data" class="solicitud-form">

        <!-- Fila 1 -->
        <div class="form-row">
            <div class="form-group">
                <label>Nombre del Fallecido</label>
                <input asp-for="NombreFallec" class="form-control" />
                <span asp-validation-for="NombreFallec" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Parentesco *</label>
                <select asp-for="Parentesco" class="form-control">
                    <option value="">Seleccionar parentesco</option>
                    <option>Padre</option>
                    <option>Madre</option>
                    <option>Esposo</option>
                    <option>Esposa</option>
                    <option>Hijo</option>
                    <option>Hija</option>
                    <option>Hermano</option>
                    <option>Hermana</option>
                    <option>Abuelo</option>
                    <option>Abuela</option>
                    <option>Otro</option>
                </select>
                <span asp-validation-for="Parentesco" class="text-danger"></span>
            </div>
        </div>

        <!-- Fila 2 -->
        <div class="form-row">
            <div class="form-group">
                <label>Fecha de Fallecimiento</label>
                <input asp-for="FechaComun" type="date" class="form-control" />
                <span asp-validation-for="FechaComun" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Lugar de Sepelio</label>
                <input asp-for="LugarSep" class="form-control" />
                <span asp-validation-for="LugarSep" class="text-danger"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Fecha de Inicio</label>
                <input asp-for="FechaIni" type="date" class="form-control" />
                <span asp-validation-for="FechaIni" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label>Fecha de Fin</label>
                <input asp-for="FechaFin" type="date" class="form-control" />
                <span asp-validation-for="FechaFin" class="text-danger"></span>
            </div>
        </div>

        <!-- Fila 3 -->
        <div class="form-row">
            <div class="form-group">
                <label>Traslado</label>
                <input asp-for="Traslado" class="form-control" placeholder="Ej: Nacional, Internacional, Otro" />
                <span asp-validation-for="Traslado" class="text-danger"></span>
            </div>
        </div>

        <!-- Documentos -->
        <div class="documentos-section">
            <h4>Documentos Requeridos</h4>
            <div class="form-row">
                <div class="upload-box">
                    <label>Partida de Defunción *</label>
                    <div class="upload-area" onclick="this.querySelector('input[type=file]').click()">
                        <input type="file" name="archivos" class="file-input" accept=".pdf,.jpg,.jpeg,.png" required onchange="updateFileName(this)" />
                        <div class="upload-icon">⬆️</div>
                        <p class="upload-text">Haz clic para seleccionar<br><span>PDF, JPG, PNG</span></p>
                        <p class="file-name" style="display:none; margin-top:10px; color:#059669; font-weight:600;"></p>
                    </div>
                </div>

                <div class="upload-box">
                    <label>DNI del Fallecido *</label>
                    <div class="upload-area" onclick="this.querySelector('input[type=file]').click()">
                        <input type="file" name="archivos" class="file-input" accept=".pdf,.jpg,.jpeg,.png" required onchange="updateFileName(this)" />
                        <div class="upload-icon">⬆️</div>
                        <p class="upload-text">Haz clic para seleccionar<br><span>PDF, JPG, PNG</span></p>
                        <p class="file-name" style="display:none; margin-top:10px; color:#059669; font-weight:600;"></p>
                    </div>
                </div>
            </div>
        </div>

   <div class="form-actions">
            <button type="submit" class="btn-submit">Adjuntar certificado médico</button>
    </div>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById("tipoSolicitud").addEventListener("change", function () {
            if (this.value) {
                window.location.href = this.value;
            }
        });
        
        // Debug: Log form submission
        document.querySelector('form').addEventListener('submit', function(e) {
            console.log('Formulario enviado');
            const formData = new FormData(this);
            for (let pair of formData.entries()) {
                console.log(pair[0] + ': ' + pair[1]);
            }
        });
        
        // Función para mostrar el nombre del archivo seleccionado
        window.updateFileName = function(input) {
            const uploadArea = input.closest('.upload-area');
            const fileNameDisplay = uploadArea.querySelector('.file-name');
            const uploadText = uploadArea.querySelector('.upload-text');
            const uploadIcon = uploadArea.querySelector('.upload-icon');
            
            if (input.files && input.files[0]) {
                const fileName = input.files[0].name;
                const fileSize = (input.files[0].size / 1024).toFixed(2) + ' KB';
                
                fileNameDisplay.textContent = '✅ ' + fileName + ' (' + fileSize + ')';
                fileNameDisplay.style.display = 'block';
                uploadText.style.display = 'none';
                uploadIcon.textContent = '✅';
                uploadArea.style.borderColor = '#059669';
                uploadArea.style.backgroundColor = '#f0fdf4';
            }
        }
    </script>
}
<style>
