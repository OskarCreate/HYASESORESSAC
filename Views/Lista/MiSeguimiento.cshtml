@model List<proyectoIngSoft.Models.MiSeguimientoViewModel>
@{
    ViewData["Title"] = "Mi Seguimiento";
    var totalSolicitudes = ViewBag.TotalSolicitudes ?? 0;
    var solicitudesActivas = ViewBag.SolicitudesActivas ?? 0;
    var solicitudesFinalizadas = ViewBag.SolicitudesFinalizadas ?? 0;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Mi Seguimiento</h2>
            <p class="text-muted mb-0">Seguimiento en tiempo real del estado de mis solicitudes</p>
        </div>
        <div class="text-end">
            <a href="@Url.Action("MisSolicitudes", "Lista")" class="btn btn-outline-primary">
                <i class="bi bi-list-ul me-1"></i> Vista de Lista
            </a>
        </div>
    </div>

    <!-- Tarjetas de Resumen -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">@totalSolicitudes</h4>
                            <p class="mb-0">Total Solicitudes</p>
                        </div>
                        <i class="bi bi-folder-plus display-6 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">@solicitudesActivas</h4>
                            <p class="mb-0">En Proceso</p>
                        </div>
                        <i class="bi bi-clock-history display-6 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h4 class="mb-0">@solicitudesFinalizadas</h4>
                            <p class="mb-0">Finalizadas</p>
                        </div>
                        <i class="bi bi-check-circle display-6 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <!-- Filtros -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Filtrar por Tipo</label>
                        <select class="form-select" id="filtroTipo">
                            <option value="todos">Todos los tipos</option>
                            <option value="Descanso Médico">Descanso Médico</option>
                            <option value="Subsidio">Subsidio</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Filtrar por Estado</label>
                        <select class="form-select" id="filtroEstado">
                            <option value="todos">Todos los estados</option>
                            <option value="En Proceso">En Proceso</option>
                            <option value="En Observación">En Observación</option>
                            <option value="Aprobado">Aprobado</option>
                            <option value="Rechazado">Rechazado</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Ordenar por</label>
                        <select class="form-select" id="ordenarPor">
                            <option value="fecha">Fecha más reciente</option>
                            <option value="progreso">Mayor progreso</option>
                            <option value="estado">Estado</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button class="btn btn-outline-secondary w-100" onclick="aplicarFiltros()">
                            <i class="bi bi-funnel me-1"></i> Aplicar Filtros
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grid de Seguimiento -->
        <div class="row" id="gridSeguimiento">
            @foreach (var solicitud in Model)
            {
                <div class="col-lg-6 col-xl-4 mb-4 solicitud-item" 
                     data-tipo="@solicitud.Tipo" 
                     data-estado="@solicitud.EstadoGeneral">
                    <div class="card h-100 shadow-sm border-0">
                        <!-- Header de la Tarjeta -->
                        <div class="card-header bg-white border-0 pb-0">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="fw-bold text-primary mb-1">Solicitud #@solicitud.IdUnico</h6>
                                    <span class="badge @GetBadgeClass(solicitud.Tipo)">@solicitud.Tipo</span>
                                </div>
                                <span class="badge @GetEstadoBadgeClass(solicitud.EstadoGeneral)">@solicitud.EstadoGeneral</span>
                            </div>
                        </div>

                        <div class="card-body">
                            <!-- Información Básica -->
                            <div class="mb-3">
                                <p class="mb-1"><strong>Motivo:</strong> @solicitud.Motivo</p>
                                <p class="mb-1"><strong>Fecha Envío:</strong> @solicitud.FechaEnvio.ToString("dd/MM/yyyy")</p>
                                <p class="mb-0"><strong>Días Totales:</strong> @solicitud.DiasTotales días</p>
                            </div>

                            <!-- Barra de Progreso -->
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted">Progreso general</small>
                                    <small class="text-muted">@solicitud.Progreso%</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar @GetProgressBarClass(solicitud.Progreso)" 
                                         role="progressbar" 
                                         style="width: @solicitud.Progreso%" 
                                         aria-valuenow="@solicitud.Progreso" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                <small class="text-muted">@solicitud.PasosCompletados de @solicitud.TotalPasos pasos completados</small>
                            </div>

                            <!-- Timeline Visual -->
                            <div class="timeline-visual mb-3">
                                @if (solicitud.Tipo == "Descanso Médico")
                                {
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 1 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>Solicitud</small>
                                        </div>
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 2 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>Asistente</small>
                                        </div>
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 3 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>ESSALUD</small>
                                        </div>
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 4 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>Jefa</small>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 1 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>Solicitud</small>
                                        </div>
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 2 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>PSA</small>
                                        </div>
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 3 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>Jefa</small>
                                        </div>
                                        <div class="timeline-step @(solicitud.PasosCompletados >= 4 ? "completed" : "")">
                                            <div class="timeline-dot"></div>
                                            <small>Subsidio</small>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Estados Detallados -->
                            <div class="estados-detallados">
                                <small class="text-muted d-block mb-1">Estados actuales:</small>
                                <div class="d-flex flex-wrap gap-1">
                                    @if (solicitud.Tipo == "Descanso Médico")
                                    {
                                        <span class="badge bg-light text-dark border">Asistente: @solicitud.EstadoESSALUD</span>
                                        <span class="badge bg-light text-dark border">ESSALUD: @solicitud.EstadoESSALUD</span>
                                        <span class="badge bg-light text-dark border">Jefa: @solicitud.EstadoProcesado</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border">PSA: @solicitud.EstadoSubsidioA</span>
                                        <span class="badge bg-light text-dark border">Jefa: @solicitud.EstadoSubsidioJ</span>
                                        <span class="badge bg-light text-dark border">Subsidio: @solicitud.EstadoGeneral</span>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Footer de la Tarjeta -->
                        <div class="card-footer bg-white border-0 pt-0">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    @solicitud.FechaInicio.ToString("dd/MM/yyyy") - @solicitud.FechaFin.ToString("dd/MM/yyyy")
                                </small>
                                <button class="btn btn-sm btn-outline-primary" onclick="verDetalleSeguimiento(@solicitud.IdDescanso)">
                                    <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-binoculars display-1 text-muted"></i>
            </div>
            <h4 class="text-muted mb-3">No hay solicitudes para seguir</h4>
            <p class="text-muted mb-4">Cuando tengas solicitudes activas, podrás ver su seguimiento aquí</p>
            <a href="@Url.Action("Index", "Solicitud")" class="btn btn-primary">
                <i class="bi bi-plus-circle me-2"></i> Crear Nueva Solicitud
            </a>
        </div>
    }
</div>

<!-- Modal para Detalles de Seguimiento -->
<div class="modal fade" id="detalleSeguimientoModal" tabindex="-1" aria-labelledby="detalleSeguimientoModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detalleSeguimientoModalLabel">Detalles de Seguimiento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="detalleSeguimientoContenido">
                <!-- Contenido cargado por AJAX -->
            </div>
        </div>
    </div>
</div>

@functions {
    public string GetBadgeClass(string tipo)
    {
        return tipo == "Descanso Médico" ? "bg-info" : "bg-warning text-dark";
    }

    public string GetEstadoBadgeClass(string estado)
    {
        return estado switch
        {
            "Aprobado" => "bg-success",
            "Rechazado" => "bg-danger",
            "En Observación" => "bg-warning text-dark",
            _ => "bg-primary"
        };
    }

    public string GetProgressBarClass(int progreso)
    {
        if (progreso >= 100) return "bg-success";
        if (progreso >= 75) return "bg-info";
        if (progreso >= 50) return "bg-primary";
        if (progreso >= 25) return "bg-warning";
        return "bg-secondary";
    }
}

<style>
    .card {
        transition: all 0.3s ease;
        border: 1px solid #e9ecef;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
    }

    .timeline-visual {
        padding: 10px 0;
    }

    .timeline-step {
        text-align: center;
        flex: 1;
        position: relative;
    }

    .timeline-step:not(:last-child)::after {
        content: '';
        position: absolute;
        top: 8px;
        right: -50%;
        width: 100%;
        height: 2px;
        background-color: #e9ecef;
        z-index: 1;
    }

    .timeline-step.completed:not(:last-child)::after {
        background-color: #198754;
    }

    .timeline-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background-color: #e9ecef;
        margin: 0 auto 5px;
        position: relative;
        z-index: 2;
    }

    .timeline-step.completed .timeline-dot {
        background-color: #198754;
        border: 2px solid #198754;
    }

    .progress {
        border-radius: 10px;
    }

    .progress-bar {
        border-radius: 10px;
        transition: width 0.6s ease;
    }

    .estados-detallados .badge {
        font-size: 0.7rem;
        padding: 0.25rem 0.5rem;
    }
</style>

@section Scripts {
    <script>
        function aplicarFiltros() {
            const filtroTipo = document.getElementById('filtroTipo').value;
            const filtroEstado = document.getElementById('filtroEstado').value;
            const ordenarPor = document.getElementById('ordenarPor').value;

            const items = document.querySelectorAll('.solicitud-item');
            
            items.forEach(item => {
                const tipo = item.getAttribute('data-tipo');
                const estado = item.getAttribute('data-estado');
                
                let mostrar = true;

                if (filtroTipo !== 'todos' && tipo !== filtroTipo) {
                    mostrar = false;
                }

                if (filtroEstado !== 'todos' && estado !== filtroEstado) {
                    mostrar = false;
                }

                item.style.display = mostrar ? 'block' : 'none';
            });

            // Ordenar items
            const grid = document.getElementById('gridSeguimiento');
            const itemsArray = Array.from(items).filter(item => item.style.display !== 'none');
            
            itemsArray.sort((a, b) => {
                if (ordenarPor === 'fecha') {
                    return 0; // Ya viene ordenado del servidor
                } else if (ordenarPor === 'progreso') {
                    const progresoA = parseInt(a.querySelector('.progress-bar').style.width);
                    const progresoB = parseInt(b.querySelector('.progress-bar').style.width);
                    return progresoB - progresoA;
                } else if (ordenarPor === 'estado') {
                    const estadoA = a.getAttribute('data-estado');
                    const estadoB = b.getAttribute('data-estado');
                    return estadoA.localeCompare(estadoB);
                }
                return 0;
            });

            // Reordenar en el DOM
            itemsArray.forEach(item => grid.appendChild(item));
        }

        function verDetalleSeguimiento(descansoId) {
            $.get('@Url.Action("DetalleSolicitud", "Lista")', { descansoId: descansoId }, function(data) {
                $('#detalleSeguimientoContenido').html(data);
                $('#detalleSeguimientoModal').modal('show');
            }).fail(function() {
                alert('Error al cargar los detalles del seguimiento');
            });
        }

        // Auto-refresh cada 30 segundos para actualizar estados
        setInterval(function() {
            console.log('Actualizando estados de seguimiento...');
            // Aquí podrías agregar una llamada AJAX para actualizar los estados
        }, 30000);
    </script>
}