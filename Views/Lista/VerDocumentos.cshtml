@model proyectoIngSoft.Models.Descanso

<div class="container py-4">
    <!-- Volver -->
    <a href="/Lista/DescansosProlongados" class="back-link mb-3 d-inline-flex align-items-center">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>

    <!-- Título -->
    <h5 class="fw-semibold mb-4 d-flex align-items-center text-primary">
        <i class="bi bi-file-earmark-text me-2"></i> Documentos del Trabajador
    </h5>

    <!-- Info del trabajador -->
    <div class="worker-card shadow-sm mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap">
            <div class="d-flex align-items-center mb-2 mb-md-0">
                <div class="worker-icon bg-primary-subtle text-primary me-3">
                    <i class="bi bi-person-fill fs-4"></i>
                </div>
                <div>
                    <p class="fw-semibold mb-1">Trabajador</p>
                    <p class="mb-0">@($"{Model.User?.Username} {Model.User?.Apellidos}")</p>
                </div>
            </div>
            <div class="d-flex align-items-center">
                <div class="worker-icon bg-success-subtle text-success me-2">
                    <i class="bi bi-credit-card-2-front-fill fs-5"></i>
                </div>
                <div>
                    <p class="fw-semibold mb-1">DNI</p>
                    <p class="mb-0">@Model.User?.Dni</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Botones -->
    <form method="post" asp-action="EliminarDocumentos" asp-controller="Lista">
        <input type="hidden" name="descansoId" value="@Model.IdDescanso" />

        <div class="action-card shadow-sm mb-3 d-flex justify-content-between align-items-center flex-wrap p-3">
            <div class="mb-2 mb-md-0">
                <button id="btnDuplicidad" type="button" class="btn btn-dup me-2">
                    <i class="bi bi-search"></i> Controlar Duplicidad
                </button>

                <!-- 🔍 Nuevo botón -->
                <button id="btnIncompletos" type="button" class="btn btn-warning me-2">
                    <i class="bi bi-exclamation-triangle"></i> Detectar Documentos Incompletos
                </button>

                <button id="btnEliminar" type="submit" class="btn btn-del" disabled>
                    <i class="bi bi-trash3"></i> Eliminar Seleccionados (0)
                </button>
            </div>
            <small class="text-muted">Total: @Model.DocumentosMedicos.Count documento(s)</small>
        </div>

        <!-- Mensaje dinámico -->
        <div id="alertContainer"></div>

        <!-- Lista -->
        <div class="card doc-card shadow-sm p-4">
            <h6 class="fw-semibold mb-3">📄 Documentos Subidos</h6>

            @if (Model.DocumentosMedicos != null && Model.DocumentosMedicos.Any())
            {
                foreach (var doc in Model.DocumentosMedicos)
                {
                    <div class="doc-item p-3 mb-3 rounded">
                        <div class="d-flex justify-content-between align-items-center flex-wrap">
                            <div class="d-flex align-items-start">
                                <input type="checkbox" class="form-check-input me-2 chkDoc mt-1" name="documentosIds" value="@doc.IdDocumento" />
                                <div>
                                    <i class="bi bi-file-earmark-pdf text-primary me-1 fs-5"></i>
                                    <strong>@doc.Nombre</strong>
                                    <div class="text-muted small mt-1">
                                        <i class="bi bi-calendar-date me-1"></i>@doc.FechaSubida.ToString("dd/MM/yyyy")
                                        <span class="ms-3"><i class="bi bi-clock me-1"></i>@doc.FechaSubida.ToString("HH:mm")</span>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-2 mt-md-0">
                                <a href="/Lista/VerDocumento/@doc.IdDocumento" target="_blank" class="btn btn-sm btn-view me-2">
                                    Ver Documento
                                </a>
                                <a href="/Lista/VerDocumento/@doc.IdDocumento" download class="btn btn-sm btn-download">
                                    Descargar
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="text-muted">No hay documentos registrados para este descanso.</p>
            }
        </div>
    </form>
</div>

<script>
    // --- CONTADOR DE SELECCIONADOS ---
    const checkboxes = document.querySelectorAll(".chkDoc");
    const btnEliminar = document.getElementById("btnEliminar");

    checkboxes.forEach(chk => {
        chk.addEventListener("change", () => {
            const seleccionados = document.querySelectorAll(".chkDoc:checked").length;
            btnEliminar.textContent = `Eliminar Seleccionados (${seleccionados})`;
            btnEliminar.disabled = seleccionados === 0;
        });
    });

    // --- CONTROLAR DUPLICIDAD ---
    document.getElementById("btnDuplicidad").addEventListener("click", function () {
        const documentos = document.querySelectorAll(".doc-item");

        if (documentos.length === 0) {
            mostrarMensaje("⚠️ No hay documentos registrados para verificar duplicados.");
            return;
        }

        limpiarAlertas(documentos, "duplicado", "dup-alert");

        const vistos = new Map();
        let duplicados = 0;

        documentos.forEach(div => {
            const nombreElem = div.querySelector("strong");
            const nombre = nombreElem.textContent.trim().toLowerCase();
            const base = normalizar(nombre);

            for (let [basePrev, divPrev] of vistos) {
                const similitud = calcularSimilitud(base, basePrev);
                if (similitud > 0.8) {
                    marcarDuplicado(div);
                    duplicados++;
                    break;
                }
            }
            vistos.set(base, div);
        });

        if (duplicados > 0) {
            mostrarMensaje(`⚠️ Se detectaron ${duplicados} documento(s) duplicado(s).`);
        } else {
            mostrarMensaje("✅ No se detecta duplicidad entre los documentos.");
        }
    });

    // --- DETECTAR DOCUMENTOS INCOMPLETOS ---
    document.getElementById("btnIncompletos").addEventListener("click", function () {
        const documentos = document.querySelectorAll(".doc-item");

        if (documentos.length === 0) {
            mostrarMensaje("⚠️ No hay documentos registrados para este trabajador.");
            return;
        }

        limpiarAlertas(documentos, "incompleto", "inc-alert");

        let incompletos = 0;

        documentos.forEach(div => {
            const nombreElem = div.querySelector("strong");
            const nombre = nombreElem.textContent.trim().toLowerCase();

            const condiciones = [
                nombre.includes("incompleto"),
                nombre.includes("borrador"),
                nombre.includes("pendiente"),
                nombre.includes("falta"),
                nombre === "" || nombre === "documento"
            ];

            const esIncompleto = condiciones.some(Boolean);

            if (esIncompleto) {
                marcarIncompleto(div);
                incompletos++;
            }
        });

        const total = documentos.length;
        const porcentaje = ((incompletos / total) * 100).toFixed(1);

        if (incompletos === 0) {
            mostrarMensaje(`✅ Todos los ${total} documentos parecen estar completos.`);
        } else if (porcentaje <= 25) {
            mostrarMensaje(`⚠️ ${incompletos} de ${total} documentos (${porcentaje}%) presentan posibles inconsistencias.`);
        } else if (porcentaje <= 60) {
            mostrarMensaje(`🚨 Atención: ${porcentaje}% de los documentos (${incompletos}/${total}) parecen incompletos o mal subidos.`);
        } else {
            mostrarMensaje(`❌ Estado crítico: ${porcentaje}% de los documentos están incompletos.`);
        }
    });

    // --- FUNCIONES AUXILIARES ---
    function mostrarMensaje(texto) {
        const alerta = document.createElement("div");
        alerta.classList.add("alert", "alert-info", "mt-3");
        alerta.style.fontWeight = "500";
        alerta.innerHTML = texto;

        // Eliminar alertas previas
        document.querySelectorAll(".alert").forEach(a => a.remove());
        document.querySelector(".card.doc-card").prepend(alerta);

        setTimeout(() => alerta.remove(), 6500);
    }

    function limpiarAlertas(documentos, claseIcono, claseDiv) {
        documentos.forEach(div => {
            div.classList.remove(claseDiv);
            const iconoPrev = div.querySelector("." + claseIcono);
            if (iconoPrev) iconoPrev.remove();
        });
    }

    function marcarIncompleto(div) {
        const nombreElem = div.querySelector("strong");
        const icono = document.createElement("span");
        icono.textContent = " ⚠️";
        icono.classList.add("incompleto");
        nombreElem.appendChild(icono);
        div.classList.add("inc-alert");
    }

    function normalizar(nombre) {
        return nombre
            .replace(/\(.*\)/, "")
            .replace(/\s+/g, "")
            .replace(/_/g, "")
            .replace(/-/g, "")
            .replace(/\.pdf$/, "")
            .toLowerCase();
    }

    function calcularSimilitud(a, b) {
        const largo = Math.max(a.length, b.length);
        let iguales = 0;
        for (let i = 0; i < Math.min(a.length, b.length); i++) {
            if (a[i] === b[i]) iguales++;
        }
        return iguales / largo;
    }

    function marcarDuplicado(div) {
        const nombreElem = div.querySelector("strong");
        const icono = document.createElement("span");
        icono.textContent = " ❌";
        icono.classList.add("duplicado");
        nombreElem.appendChild(icono);
        div.classList.add("dup-alert");
    }


</script>



<!-- 🪟 Modal vacío donde se cargará el detalle -->
<div class="modal fade" id="detalleModalProcesadas" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="detalleContenidoProcesadas">
            <!-- Aquí se inyecta _DetalleDescanso.cshtml -->
        </div>
    </div>
</div>

<!-- 🔽 jQuery y Bootstrap (si no están ya en tu Layout) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<!-- 🧠 Script para abrir el modal -->
<script>
    function abrirModalDetalleDescanso(id) {
        $.ajax({
            url: '/HU8/DetalleDescanso/' + id, // 👈 usa la acción real
            type: 'GET',
            success: function (data) {
                $('#detalleContenidoProcesadas').html(data);
                $('#detalleModalProcesadas').modal('show');
            },
            error: function () {
                alert('No se pudieron cargar los detalles del descanso médico.');
            }
        });
    }
</script>



<!-- === CSS === -->
<style>
    body {
        background-color: #f9fafc;
        font-family: 'Segoe UI', sans-serif;
        color: #333;
    }

    .btn-warning {
        border: 2px solid #ffc107;
        background-color: #fffbea;
        color: #b58105;
        font-weight: 500;
        border-radius: 10px;
        transition: 0.2s;
    }
    .btn-warning:hover { background-color: #ffe58a; }

    .incompleto {
        color: #ff8800;
        font-weight: bold;
        margin-left: 3px;
    }

    .inc-alert {
        background-color: #fff8e1;
        border-color: #ffe58a !important;
    }

    .alert {
        border-radius: 10px;
        font-weight: 500;
        text-align: center;
    }
</style>

