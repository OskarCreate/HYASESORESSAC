@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    // Obtener datos de la sesión
    var userEmail = HttpContextAccessor.HttpContext?.Session.GetString("User");
    var rol = HttpContextAccessor.HttpContext?.Session.GetString("Rol");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HYasesoresSAC</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

    <!-- Select2 CSS -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.1.0-rc.0/css/select2.min.css" rel="stylesheet" />

    <!-- Site Styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/proyectoIngSoft.styles.css" asp-append-version="true" />

    <!-- Estilos específicos de cada vista -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">HY ASESORES S.A.C.</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" 
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">

                        @if (!string.IsNullOrEmpty(userEmail))
                        {
                            @* ===================== ROL: JEFE ===================== *@
                            @if (rol == "Jefe")
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="gestionDropdown" role="button" data-bs-toggle="dropdown">
                                        Control
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Lista" asp-action="Index">Lista</a></li>
                                        <li><a class="dropdown-item" asp-controller="Lista" asp-action="DescansosProlongados">Verificar formatos y vigencias con PCA(subsidios)</a></li>
                                        <li><a class="dropdown-item" asp-controller="Lista" asp-action="SubsidiosJefe">Control de subsidios</a></li>
                                        <li><a class="dropdown-item" asp-controller="Lista" asp-action="SupervisionSubsidios">Control de Subsidios por Descanso Médico</a></li>
                                        <li><a class="dropdown-item" asp-controller="SistemaSolicitud" asp-action="ListaSolicitudes">Ver Lista de Solicitudes</a></li>
                                        <li><a class="dropdown-item" asp-controller="Historial" asp-action="Index">Lista Historial de reportes de descaso médico y subsidios</a></li>
                                        <li><a class="dropdown-item" asp-controller="HU15" asp-action="Index">Documentos del Trabajador</a></li>
                                    </ul>
                                </li>

                                <li><a class="nav-link text-dark" asp-controller="Calendario" asp-action="Index">Calendario</a></li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="monitoreoDropdown" role="button" data-bs-toggle="dropdown">
                                        Monitoreo
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Monitoreo" asp-action="Index">Monitoreo de Subsidios</a></li>
                                        <li><a class="dropdown-item" asp-controller="Trabajadores" asp-action="Index">Días acumulados</a></li>
                                        <li><a class="dropdown-item" asp-controller="Lista" asp-action="ReporteMensual">Reporte Anual de descansos médicos y Subsidios</a></li>
                                        <li><a class="dropdown-item" asp-controller="Monitoreo" asp-action="HU16">Historial de importe de pagos anuales</a></li>
                                    </ul>
                                </li>

                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="notifDropdown" role="button" data-bs-toggle="dropdown">
                                        Notificaciones
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" href="/Simulaciones/CrearNotificacion">Notificar actividad del trabajador</a></li>
                                    </ul>
                                </li>
                            }

                            @* ===================== ROL: BIENESTAR ===================== *@
                            else if (rol == "Bienestar")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Lista" asp-action="Index">Lista</a>
                                </li>
                                <li>
                                    <a class="nav-link text-dark" asp-controller="SistemaSolicitud" asp-action="ListaSolicitudes">Ver Lista de Solicitudes</a>
                                </li>
                            }

                            @* ===================== ROL: EMPLEADO / TRABAJADOR ===================== *@
                            else if (rol == "Empleado" || rol == "Trabajador")
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle text-dark" href="#" id="empleadoDropdown" role="button" data-bs-toggle="dropdown">
                                        Opciones
                                    </a>
                                    <ul class="dropdown-menu">
                                        <li><a class="dropdown-item" asp-controller="Lista" asp-action="MisSolicitudes">Mis Solicitudes</a></li>
                                        <li><a class="dropdown-item" asp-controller="SistemaSolicitud" asp-action="Index">Solicitudes</a></li>
                                    </ul>
                                </li>
                            }
                        }

                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HYasesores -
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
